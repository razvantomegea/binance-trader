{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pnpm install --frozen-lockfile"
  },
  "deploy": {
    "startCommand": "node scripts/trigger-strategy-cron.mjs",
    "cronSchedule": "*/15 * * * *",
    "restartPolicyType": "NEVER"
  }
}
