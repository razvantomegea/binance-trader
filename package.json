{
  "name": "binance-trading",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "backtest": "node scripts/run-backtest.mjs",
    "analyze:post-close": "node scripts/analyze-post-close-24h.mjs",
    "backtest:cleanup": "node scripts/cleanup-backtest-reports.mjs",
    "backtest:cache:cleanup": "node scripts/cleanup-backtest-cache.mjs",
    "ml:dataset": "node scripts/run-ml.mjs dataset",
    "ml:train": "node scripts/run-ml.mjs train",
    "ml:eval": "node scripts/run-ml.mjs eval",
    "ml:optimize": "node scripts/run-ml.mjs optimize",
    "db:push": "drizzle-kit push",
    "cron:trigger": "node scripts/trigger-strategy-cron.mjs",
    "railway:up": "pnpm run railway:up:web",
    "railway:up:web": "node scripts/railway-up.mjs RAILWAY_WEB_SERVICE",
    "railway:up:cron": "node scripts/railway-up.mjs RAILWAY_CRON_SERVICE",
    "fallow": "fallow",
    "fallow:audit": "fallow audit",
    "fallow:dead-code": "fallow dead-code",
    "fallow:dupes": "fallow dupes",
    "fallow:health": "fallow health",
    "fallow:fix-dry-run": "fallow fix --dry-run"
  },
  "dependencies": {
    "@neondatabase/serverless": "1.0.2",
    "clsx": "2.1.1",
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-is": "19.2.4",
    "recharts": "3.8.1",
    "web-push": "3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@railway/cli": "5.4.2",
    "@tailwindcss/postcss": "4.3.0",
    "@tensorflow/tfjs": "4.22.0",
    "@types/node": "20.19.42",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/web-push": "3.6.4",
    "dotenv": "17.4.2",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "fallow": "2.89.0",
    "prettier": "3.8.3",
    "tailwindcss": "4.3.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  },
  "pnpm": {
    "overrides": {
      "react-is": "19.2.4",
      "postcss": "8.5.15",
      "tar": ">=7.5.7",
      "@railway/cli>tar": "6.2.1",
      "drizzle-kit>@esbuild-kit/esm-loader": "npm:tsx@4.22.4",
      "@railway/cli>node-fetch": "npm:node-fetch@2.7.0"
    },
    "onlyBuiltDependencies": [
      "@railway/cli",
      "esbuild"
    ],
    "ignoredBuiltDependencies": [
      "core-js",
      "sharp",
      "unrs-resolver"
    ]
  }
}
